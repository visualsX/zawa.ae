---

<Layout
  title="Ag-Tech & Vertical Farming Solutions | Zahra Al Warsan"
  description="Modernizing agriculture in Dubai with smart irrigation, climate-controlled greenhouses, and advanced vertical farming technology."
>
  <ServiceHero
    title="Ag-Tech Solutions"
    description="Empowering the future of farming with innovative agricultural technology tailored for efficiency, sustainability, and high yield."
  >
    <img
      fetchpriority="high"
      src="/icons/agtech.svg"
      alt=""
      class="absolute z-1 pointer-events-none right-0 top-5 w-96 sm:w-60 md:w-70"
      aria-hidden="true"
    />
  </ServiceHero>

  <ServiceGrid title="Our Ag-Tech Services" services={gridServices} />

  <ServiceInfoBox
    question="Are you a commercial grower or investor?"
    subtext="Looking for a technology partner to design and scale your next agricultural venture? We'd love to help!"
  />

  <ServiceDetails services={detailedServices} />

  <ServiceBenefits
    title="We believe in cultivating the future of farming with innovative technology. That's why we build sustainable, high-yield agricultural systems tailored for your success."
  />

  <Faqs faqs={faqs} title="Your agricultural technology questions answered" />

  <script>
    document.addEventListener("DOMContentLoaded", () => {
      document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
        anchor.addEventListener("click", function (e) {
          const targetId = this.getAttribute("href");
          if (targetId === "#contact" || targetId === "#") return;

          const targetElement = document.querySelector(targetId);
          if (targetElement) {
            e.preventDefault();
            targetElement.scrollIntoView({
              behavior: "smooth",
              block: "start",
            });
            history.pushState(null, "", targetId);
          }
        });
      });
    });
  </script>
</Layout>
