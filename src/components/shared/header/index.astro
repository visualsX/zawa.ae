<header
  class="fixed top-6 left-0 right-0 z-999 flex justify-center w-full px-6"
>
  <div
    class="bg-cream border border-gray-300 rounded-full w-full max-w-6xl flex items-center justify-between px-4 py-4 shadow-sm"
  >
    <!-- Logo -->
    <a href="/" class="flex items-center gap-3">
      <img
        class="w-12 h-12"
        fetchpriority="high"
        src="/logo.png"
        alt=""
        aria-hidden="true"
      />
      <span
        class="font-beautify font-bold text-rust text-[1.1rem] leadxl.1] uppercase"
      >
        <p class="font-extrabold tracking-[0.5em]">Zahra</p>
        <p>Al Warsan</p>
      </span>
    </a>

    <!-- Nav -->
    <nav class="hidden lg:flex items-center gap-8">
      <a
        href="#"
        class="text-[15px] text-forest font-sora font-medium flex items-center gap-1 hover:opacity-80 transition-opacity"
      >
        Services
        <svg
          class="w-4 h-4"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M19 9l-7 7-7-7"></path></svg
        >
      </a>
      <a
        href="#"
        class="text-[15px] text-forest font-sora font-medium hover:opacity-80 transition-opacity"
        >Blog</a
      >
      <a
        href="#"
        class="text-[15px] text-forest font-sora font-medium hover:opacity-80 transition-opacity"
        >FAQ</a
      >
      <a
        href="#"
        class="text-[15px] text-forest font-sora font-medium flex items-center gap-1 hover:opacity-80 transition-opacity"
      >
        Contact
      </a>
    </nav>

    <!-- CTA -->
    <a
      href="#"
      class="bg-forest text-cream font-sora px-6 py-2.5 rounded-full text-[15px] font-medium hover:bg-opacity-90 transition-colors"
    >
      Get a Quote
    </a>
  </div>
</header>
