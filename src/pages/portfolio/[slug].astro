---
import Layout from "../../layouts/Layout.astro";
import { Image } from "astro:assets";
import { projects } from "../../data/portfolio";

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
---

<Layout
  title={`${project.title} | Portfolio | Zahra Al Warsan`}
  description={project.description}
  image={project.image.src}
>
  <!-- Hero Section -->
  <section
    class="relative z-20 w-full bg-forest pt-40 pb-24 px-4 sm:px-6 overflow-hidden"
  >
    <div class="container-custom relative z-10">
      <!-- <a
        href="/portfolio"
        class="inline-flex items-center gap-2 font-sora text-sm text-cream/60 hover:text-cream transition-colors mb-8"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="m15 18-6-6 6-6"></path>
        </svg>
        Back to Portfolio
      </a> -->
      <span
        class="inline-block font-sora text-base font-bold text-teal tracking-wider mb-4"
      >
        {project.category}.
      </span>
      <h1
        class="font-awesome text-4xl sm:text-5xl md:text-6xl text-cream font-bold mb-6 leading-tight"
      >
        {project.title}
      </h1>
      <p class="text-cream/90 text-lg sm:text-xl max-w-2xl font-sora">
        {project.description}
      </p>

      <div
        class="flex flex-col sm:flex-row gap-5 sm:gap-10 items-start sm:items-center mt-7 sm:mt-10 opacity-35"
      >
        <div class="flex gap-x-2 items-center">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="32"
            height="32"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.25"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="text-cream"
            ><path
              d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"
            ></path><circle cx="12" cy="10" r="3"></circle></svg
          >
          <div class="">
            <span class="font-sora text-sm text-cream/90">Client:</span>
            <p class="font-sora text-sm text-cream/90">{project.client}</p>
          </div>
        </div>
        <div class="flex gap-x-2 items-center">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="32"
            height="32"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.25"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="text-cream"
            ><path d="M19 16v-2a2 2 0 0 0-4 0v2"></path><path
              d="M9.5 15H7a4 4 0 0 0-4 4v2"></path><circle cx="10" cy="7" r="4"
            ></circle><rect x="13" y="16" width="8" height="5" rx=".899"
            ></rect></svg
          >
          <div class="">
            <span class="font-sora text-sm text-cream/90">Location:</span>
            <p class="font-sora text-sm text-cream/90">{project.location}</p>
          </div>
        </div>
      </div>
      <img
        fetchpriority="high"
        src="/icons/phool.svg"
        alt=""
        class="absolute z-1 pointer-events-none right-0 top-0 w-96 sm:w-60 md:w-70 hidden md:block opacity-20"
        aria-hidden="true"
      />
    </div>
  </section>

  <!-- Hero Image -->
  <!-- <section class="relative z-20 bg-cream md:px-6">
    <div class="container-custom">
      <img
        src={project.image}
        alt={project.title}
        class="w-full aspect-video object-cover md:rounded-b-2xl shadow-elevated"
      />
    </div>
  </section> -->

  <!-- Case Study Section -->
  <section class="relative z-20 bg-cream py-16 sm:py-24 md:px-6">
    <div class="container-custom">
      <h2
        class="font-awesome text-3xl sm:text-4xl md:text-5xl text-forest font-bold mb-16 text-center"
      >
        Case Study
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-20">
        <!-- Challenge -->
        <div class="bg-white/30 rounded-2xl p-6 sm:p-8 shadow-card">
          <div
            class="w-12 h-12 rounded-xl bg-olive/50 flex items-center justify-center mb-5"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="text-cream"
            >
              <path
                d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"
              ></path>
              <path d="M12 9v4"></path>
              <path d="M12 17h.01"></path>
            </svg>
          </div>
          <h3 class="font-awesome text-xl text-forest font-bold mb-3">
            The Challenge
          </h3>
          <p class="font-sora text-sm text-forest/70 leading-relaxed">
            {project.caseStudy.challenge}
          </p>
        </div>

        <!-- Solution -->
        <div class="bg-white/30 rounded-2xl p-6 sm:p-8 shadow-card">
          <div
            class="w-12 h-12 rounded-xl bg-olive/50 flex items-center justify-center mb-5"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="text-cream"
            >
              <path
                d="M12 22a7 7 0 0 0 7-7c0-2-1-3.9-3-5.5s-3.5-4-4-6.5c-.5 2.5-2 4.9-4 6.5C6 11.1 5 13 5 15a7 7 0 0 0 7 7z"
              ></path>
            </svg>
          </div>
          <h3 class="font-awesome text-xl text-forest font-bold mb-3">
            Our Solution
          </h3>
          <p class="font-sora text-sm text-forest/70 leading-relaxed">
            {project.caseStudy.solution}
          </p>
        </div>

        <!-- Result -->
        <div class="bg-white/30 rounded-2xl p-6 sm:p-8 shadow-card">
          <div
            class="w-12 h-12 rounded-xl bg-olive/50 flex items-center justify-center mb-5"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="text-cream"
            >
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
              <path d="m9 11 3 3L22 4"></path>
            </svg>
          </div>
          <h3 class="font-awesome text-xl text-forest font-bold mb-3">
            The Result
          </h3>
          <p class="font-sora text-sm text-forest/70 leading-relaxed">
            {project.caseStudy.result}
          </p>
        </div>
      </div>

      <!-- Key Outcomes -->
      <div class="bg-forest rounded-2xl p-8 sm:p-12 mb-20">
        <h3
          class="font-awesome text-2xl sm:text-3xl text-cream font-bold mb-8 text-center"
        >
          Key Outcomes
        </h3>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
          {
            project.outcomes.map((outcome: string, i: number) => (
              <div class="text-center bg-white/10 rounded-2xl p-6">
                <div class="w-14 h-14 rounded-full flex items-center justify-center mx-auto mb-4">
                  <span class="font-almendra text-4xl text-olive font-bold">
                    #0{i + 1}
                  </span>
                </div>
                <p class="font-sora text-sm text-cream/50 leading-relaxed">
                  {outcome}
                </p>
              </div>
            ))
          }
        </div>
      </div>

      <!-- Project Gallery -->
      {
        project.gallery &&
          project.gallery.filter((g: any) => g.when === "before").length >
            0 && (
            <div class="mb-20">
              <h3 class="font-awesome text-2xl sm:text-3xl md:text-4xl text-forest font-bold mb-10 text-center">
                The Canvas: Before the Transformation
              </h3>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                {project.gallery
                  .filter((g: any) => g.when === "before")
                  .map((item: any) => (
                    <div class="relative group overflow-hidden rounded-2xl shadow-card">
                      <span class="absolute top-4 left-4 z-10 bg-forest/80 text-cream font-sora text-xs font-semibold px-4 py-1.5 rounded-full backdrop-blur-sm">
                        {item.caption}
                      </span>
                      <Image
                        src={item.image}
                        alt={item.caption}
                        class="w-full aspect-4/3 object-cover transition-transform duration-700 group-hover:scale-105"
                      />
                    </div>
                  ))}
              </div>
            </div>
          )
      }

      {
        project.gallery &&
          project.gallery.filter((g: any) => g.when === "after").length > 0 && (
            <div>
              <h3 class="font-awesome text-2xl sm:text-3xl md:text-4xl text-forest font-bold mb-10 text-center">
                The Masterpiece: After Our Work
              </h3>
              <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                {project.gallery
                  .filter((g: any) => g.when === "after")
                  .map((item: any) => (
                    <div class="relative group overflow-hidden rounded-2xl shadow-card">
                      <span class="absolute top-4 left-4 z-10 bg-teal/80 text-white font-sora text-xs font-semibold px-4 py-1.5 rounded-full backdrop-blur-sm">
                        {item.caption}
                      </span>
                      <Image
                        src={item.image}
                        alt={item.caption}
                        class="w-full aspect-4/3 object-cover transition-transform duration-700 group-hover:scale-105"
                      />
                    </div>
                  ))}
              </div>
            </div>
          )
      }
    </div>
  </section>

  <!-- CTA Section -->
  <section class="relative z-20 bg-forest py-20 sm:py-28 px-4 sm:px-6">
    <div class="container-custom text-center flex flex-col items-center">
      <h2
        class="font-awesome text-3xl sm:text-4xl md:text-5xl text-cream font-bold mb-6 max-w-2xl leading-tight"
      >
        Want similar results for your property?
      </h2>
      <p class="font-sora text-cream/80 text-lg mb-10 max-w-xl">
        Let's discuss your project. We provide free consultations and customized
        solutions for every space.
      </p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a
          href="/contact"
          class="inline-block bg-teal text-white font-sora font-semibold px-10 py-4 rounded-full hover:bg-opacity-90 transition-all duration-300 transform hover:-translate-y-1 shadow-lg text-lg"
        >
          Give us a call
        </a>
        <a
          href="/portfolio"
          class="inline-block border border-cream/30 text-cream font-sora font-semibold px-10 py-4 rounded-full hover:bg-cream/10 transition-all duration-300 text-lg"
        >
          View more projects
        </a>
      </div>
    </div>
  </section>
</Layout>
