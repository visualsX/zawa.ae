      aria-hidden="true"
    />
  </ServiceHero>

  <ServiceGrid title="What services do we offer?" services={gridServices} />

  <ServiceInfoBox
    question="Don’t see your type of business listed?"
    subtext="Don’t worry, we’re happy to help any company or organization with outdoor spaces make them wonderful."
  />

  <ServiceDetails services={detailedServices} />

  <ServiceBenefits />

  <Faqs faqs={faqs} title="Your landscaping questions answered" />
  <!-- <section class="w-full bg-cream py-16 sm:py-24 md:py-32 relative z-20">
