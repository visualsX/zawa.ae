<style>
  /* Hero Section */
  .hero {
    position: relative;
    width: 100%;
    height: 100vh;
    background-color: #e8521f;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  /* Contact Info (Top Right) */
  .contact-info {
    position: absolute;
    top: 2.5rem;
    right: 20%;
    display: flex;
    align-items: center;
    gap: 1.5rem;
    z-index: 100;
    opacity: 0;
  }

  .contact-item {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    text-decoration: none;
    color: #ffffff;
    transition:
      opacity 0.2s ease,
      transform 0.2s ease;
  }

  .contact-item:hover {
    opacity: 0.85;
    transform: translateY(-1px);
  }

  .contact-label {
    font-family: "Inter", "Helvetica Neue", Arial, sans-serif;
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    opacity: 0.6;
    margin-bottom: 2px;
  }

  .contact-value {
    font-family: "Inter", "Helvetica Neue", Arial, sans-serif;
    font-size: 0.9rem;
    font-weight: 500;
  }

  .contact-divider {
    width: 1px;
    height: 24px;
    background-color: rgba(255, 255, 255, 0.2);
  }

  /* Decorative Icons - shared */
  .icon {
    position: absolute;
    pointer-events: none;
    z-index: 1;
  }

  /* Cloud left - partially off screen, top-left */
  .icon-cloud-left {
    top: 5%;
    left: -2%;
    width: 130px;
    opacity: 0.95;
    animation: floatSlow 8s ease-in-out infinite;
  }

  /* Cloud right - top-right area */
  .icon-cloud-right {
    top: 4%;
    right: 1%;
    width: 120px;
    opacity: 0.95;
    animation: floatSlow 7s ease-in-out infinite 1s;
  }

  /* Bee 1 - upper left area, small */
  .icon-bee-1 {
    top: 16%;
    left: 14%;
    width: 32px;
    animation: buzzFloat 4s ease-in-out infinite;
  }

  /* Bee 2 - right side, near top */
  .icon-bee-2 {
    top: 24%;
    right: 4%;
    width: 28px;
    transform: rotate(-90deg);
    animation: buzzFloatneg-90 5s ease-in-out infinite 2s;
  }

  /* Cloud loop - bottom left, dashed arc */
  .icon-cloudloop {
    top: 18%;
    /* left: -1%; */
    width: 100px;
    opacity: 0.9;
    animation: floatSlow 9s ease-in-out infinite 0.5s;
  }

  /* Flying mosquito - bottom left with trail */
  .icon-mosquito {
    bottom: 12%;
    left: -1%;
    width: 210px;
    animation: mosquitoFly 6s ease-in-out infinite;
  }

  /* Cart with flower - bottom right, large */
  .icon-cart {
    bottom: 20%;
    right: -3%;
    width: clamp(300px, 32vw, 480px);
    z-index: 2;
    animation: cartBob 5s ease-in-out infinite;
  }

  /* Hero Content */
  .hero-content {
    position: relative;
    z-index: 3;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
    padding: 0 1.5rem;
  }

  .hero-title {
    font-family: "Georgia", "Times New Roman", serif;
    font-size: clamp(2rem, 5.5vw, 3.2rem);
    font-weight: 400;
    color: #fff;
    line-height: 1.2;
    letter-spacing: -0.02em;
    margin: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }

  .title-line-wrapper {
    display: block;
    overflow: hidden;
    padding-bottom: 0.1em;
  }

  .title-line {
    display: block;
    transform: translateY(102%);
    opacity: 0;
  }

  .hero-buttons {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
    opacity: 0;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.75rem 1.75rem;
    border-radius: 6px;
    font-family: "Inter", "Helvetica Neue", Arial, sans-serif;
    font-size: 0.9rem;
    font-weight: 500;
    text-decoration: none;
    transition: all 0.25s ease;
    cursor: pointer;
    border: 1.5px solid #1a1108;
  }

  .btn-primary {
    background-color: #faf3e8;
    color: #1a1108;
  }

  .btn-primary:hover {
    background-color: #1a1108;
    color: #faf3e8;
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.15);
  }

  .btn-secondary {
    background-color: #faf3e8;
    color: #1a1108;
  }

  .btn-secondary:hover {
    background-color: #1a1108;
    color: #faf3e8;
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.15);
  }

  /* Marquee */
  .marquee-wrapper {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    /* background-color: red; */
    /* border-top: 1.5px solid #1a1108; */
    padding: 0.45rem 0;
    overflow: hidden;
    z-index: 10;
  }

  .marquee-track {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    white-space: nowrap;
    animation: marqueeScroll 25s linear infinite;
    width: max-content;
  }

  .marquee-item {
    font-family: "Inter", "Helvetica Neue", Arial, sans-serif;
    font-size: clamp(0.8rem, 2vw, 1.4rem);
    font-weight: 400;
    color: #fff;
    /* font-style: italic; */
    letter-spacing: 0.01em;
  }

  .marquee-separator {
    color: #fff;
    font-size: 0.5rem;
    opacity: 0.5;
  }

  /* Animations */
  @keyframes floatSlow {
    0%,
    100% {
      transform: translateY(0px);
    }
    50% {
      transform: translateY(-12px);
    }
  }

  @keyframes buzzFloat {
    0%,
    100% {
      transform: translate(0, 0) rotate(0deg);
    }
    25% {
      transform: translate(5px, -8px) rotate(3deg);
    }
    50% {
      transform: translate(-3px, -4px) rotate(-2deg);
    }
    75% {
      transform: translate(4px, -10px) rotate(2deg);
    }
  }
  @keyframes buzzFloatneg-90 {
    0%,
    100% {
      transform: translate(0, 0) rotate(-90deg);
    }
    25% {
      transform: translate(5px, -8px) rotate(-93deg);
    }
    50% {
      transform: translate(-3px, -4px) rotate(-92deg);
    }
    75% {
      transform: translate(4px, -10px) rotate(-92deg);
    }
  }

  @keyframes mosquitoFly {
    0%,
    100% {
      transform: translate(0, 0) rotate(0deg);
    }
    25% {
      transform: translate(8px, -6px) rotate(2deg);
    }
    50% {
      transform: translate(-4px, 4px) rotate(-1deg);
    }
    75% {
      transform: translate(6px, -8px) rotate(3deg);
    }
  }

  @keyframes cartBob {
    0%,
    100% {
      transform: translateY(0px);
    }
    50% {
      transform: translateY(-6px);
    }
  }

  @keyframes marqueeScroll {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  /* Responsive */
  @media (max-width: 768px) {
    .contact-info {
      top: 1.5rem;
      right: 50%;
      transform: translateX(50%);
      width: 90%;
      justify-content: center;
      gap: 1rem;
    }

    .contact-item {
      align-items: center;
    }

    .contact-value {
      font-size: 0.8rem;
    }

    .icon-cloud-left {
      width: 80px;
      top: 10%;
    }

    .icon-cloud-right {
      width: 70px;
      top: 8%;
    }

    .icon-bee-1 {
      width: 22px;
    }

    .icon-bee-2 {
      width: 20px;
    }

    .icon-mosquito {
      width: 100px;
      bottom: 18%;
    }

    .icon-cloudloop {
      width: 70px;
    }

    .icon-cart {
      width: 200px;
      bottom: 6%;
    }

    .hero-buttons {
      gap: 0.75rem;
    }

    .btn {
      padding: 0.6rem 1.25rem;
      font-size: 0.8rem;
    }
  }
</style>

<script>
  import { animate, stagger } from "motion";

  function initAnimations() {
    // 1. Animate title lines (slide up and fade in)
    animate(
      ".title-line",
      { transform: ["translateY(100%)", "translateY(0%)"], opacity: [0, 1] },
      {
        duration: 0.9,
        delay: stagger(0.15),
        ease: [0.16, 1, 0.3, 1] // Premium cubic-bezier (easeOutExpo)
      }
    );

    // 2. Animate buttons (fade in and slide up)
    animate(
      ".hero-buttons",
      { opacity: [0, 1], transform: ["translateY(20px)", "translateY(0px)"] },
      {
        duration: 0.8,
        delay: 0.45,
        ease: "easeOut"
      }
    );

    // 3. Animate contact info (fade in and slide down)
    animate(
      ".contact-info",
      { opacity: [0, 1], transform: ["translateY(-15px)", "translateY(0px)"] },
      {
        duration: 0.8,
        delay: 0.6,
        ease: "easeOut"
      }
    );
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initAnimations);
  } else {
    initAnimations();
  }
</script>
