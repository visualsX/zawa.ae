<script>
  function setSpacerHeight() {
    const footer = document.getElementById("parallax-footer");
    const spacer = document.getElementById("parallax-spacer");
    if (footer && spacer) {
      spacer.style.height = `${footer.offsetHeight - 100}px`;
    }
  }

  // Set initial height
  setSpacerHeight();

  // Update height on resize
  window.addEventListener("resize", setSpacerHeight);

  // Re-calc after fonts/images load
  window.addEventListener("load", setSpacerHeight);
</script>
