---
import Accordion from "../../shared/accordion.astro";

const faqs = [
  {
    question: "What makes your Company different?",
    answer:
      "We combine eco-friendly treatments with data-driven scheduling, so your lawn gets exactly what it needs, when it needs it, without unnecessary chemical use.",
  },
  {
    question: "Do you Serve My Area?",
    answer:
      "We currently serve the greater metro area and surrounding suburbs. Enter your zip code at checkout or give us a call to confirm coverage for your specific location.",
  },
  {
    question: "Do you Offer Free Consultations?",
    answer: "Yes.",
  },
  {
    question: "What Services does your company offer?",
    answer:
      "Fertilization, irrigation, pest & mosquito control, landscape design, hardscaping, and seasonal maintenance contracts, everything your yard needs, year-round.",
  },
];
---

<section class="w-full bg-cream rounded-b-4xl py-24 md:py-32 relative z-20">
  <div class="max-w-3xl mx-auto px-6 flex flex-col items-center">
    <h2
      class="font-awesome text-5xl md:text-6xl text-forest text-center mb-16 md:mb-20 max-w-2xl leading-[1.1]"
    >
      Your landscaping & maintenance questions answered
    </h2>

    <Accordion items={faqs} class="mb-24 md:mb-32" />

    <div class="text-center flex flex-col items-center">
      <h2
        class="font-awesome text-[4.5rem] md:text-[6.5rem] text-rust leading-[0.9] mb-8"
      >
        Still have<br />questions?
      </h2>
      <button
        class="border border-forest text-forest px-8 py-3 rounded-full text-sm font-sora font-medium hover:bg-forest/5 transition-colors cursor-pointer"
      >
        Give us a call
      </button>
    </div>
  </div>
</section>
