<header
  id="site-header"
  class="fixed top-4 sm:top-6 left-0 right-0 z-999 flex justify-center w-full px-4 sm:px-6"
>
  <div
    id="glass-nav"
    class="relative bg-cream/50 backdrop-blur-xl backdrop-saturate-150 border border-white/40 rounded-full w-full max-w-6xl flex items-center justify-between px-3 py-2.5 sm:px-4 sm:py-4 shadow-[0_8px_32px_rgba(0,0,0,0.08),inset_0_1px_1px_rgba(255,255,255,0.6)] overflow-hidden transition-all duration-300"
  >
    <!-- Shine layer that follows cursor -->
    <div
      id="glass-shine"
      class="pointer-events-none absolute inset-0 opacity-0 transition-opacity duration-300"
      style="background: radial-gradient(180px circle at var(--x, 50%) var(--y, 50%), rgba(255,255,255,0.5), transparent 70%);"
    >
    </div>

    <!-- Logo -->
    <a href="/" class="relative flex items-center gap-2 sm:gap-3 shrink-0">
      <img
        class="w-9 h-9 sm:w-14 sm:h-14"
        fetchpriority="high"
        src="/logo.png"
        alt=""
        aria-hidden="true"
      />
      <span
        class="font-sora font-bold text-forest text-[0.85rem] sm:text-[1.1rem] leading-[1.9]"
      >
        <p class="font-extrabold text-2xl">Zahra</p>
        <p class="text-sm">Al Warsan</p>
      </span>
    </a>

    <!-- Nav (desktop) -->
    <nav class="relative hidden lg:flex items-center gap-8">
      <a
        href="#"
        class="text-[15px] text-forest font-sora font-medium flex items-center gap-1 hover:opacity-80 transition-opacity"
      >
        Services
        <svg
          class="w-4 h-4"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M19 9l-7 7-7-7"></path></svg
        >
      </a>

      <a
        href="#"
        class="text-[15px] text-forest font-sora font-medium hover:opacity-80 transition-opacity"
        >Blog</a
      >

      <a
        href="#"
        class="text-[15px] text-forest font-sora font-medium hover:opacity-80 transition-opacity"
        >FAQ</a
      >

      <a
        href="#"
        class="text-[15px] text-forest font-sora font-medium flex items-center gap-1 hover:opacity-80 transition-opacity"
      >
        Contact
      </a>
    </nav>

    <!-- Right side: CTA + hamburger -->
    <div class="relative flex items-center gap-2 sm:gap-3">
      <!-- CTA -->

      <a
        href="#"
        class="bg-forest text-cream font-sora px-4 py-2 sm:px-6 sm:py-2.5 rounded-full text-xs sm:text-[15px] font-medium hover:bg-forest/90 transition-colors"
      >
        Get a Quote
      </a>

      <!-- Hamburger (mobile/tablet) -->
      <button
        id="mobile-menu-toggle"
        type="button"
        class="lg:hidden flex items-center justify-center w-9 h-9 sm:w-10 sm:h-10 rounded-full hover:bg-forest/10 transition-colors cursor-pointer"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <svg
          id="hamburger-icon"
          class="w-5 h-5 sm:w-6 sm:h-6 text-forest transition-opacity"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
        <svg
          id="close-icon"
          class="w-5 h-5 sm:w-6 sm:h-6 text-forest hidden transition-opacity"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu panel -->
  <div
    id="mobile-menu"
    class="lg:hidden absolute top-full left-4 right-4 sm:left-6 sm:right-6 mt-3 bg-cream/70 backdrop-blur-xl backdrop-saturate-150 border border-white/40 rounded-2xl shadow-[0_8px_32px_rgba(0,0,0,0.1)] overflow-hidden transition-all duration-300 ease-out max-h-0 opacity-0 pointer-events-none"
  >
    <nav class="flex flex-col p-6 gap-1">
      <a
        href="#"
        class="text-base text-forest font-sora font-medium py-3 hover:text-teal transition-colors"
        >Services</a
      >

      <a
        href="#"
        class="text-base text-forest font-sora font-medium py-3 hover:text-teal transition-colors"
        >Blog</a
      >

      <a
        href="#"
        class="text-base text-forest font-sora font-medium py-3 hover:text-teal transition-colors"
        >FAQ</a
      >

      <a
        href="#"
        class="text-base text-forest font-sora font-medium py-3 hover:text-teal transition-colors"
        >Contact</a
      >
    </nav>
  </div>
</header>

