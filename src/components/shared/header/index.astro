---
interface ServiceMenuItem {
  title: string;
  description: string;
  href: string;
  icon: string;
}

const serviceMenuItems: ServiceMenuItem[] = [
  {
    title: "Landscape Design",
    description:
      "From seasonal planting to full landscape transformations, we design and maintain outdoor spaces that thrive year-round.",
    href: "/services/landscape-design",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-castle-icon lucide-castle"><path d="M10 5V3"/><path d="M14 5V3"/><path d="M15 21v-3a3 3 0 0 0-6 0v3"/><path d="M18 3v8"/><path d="M18 5H6"/><path d="M22 11H2"/><path d="M22 9v10a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V9"/><path d="M6 3v8"/></svg>`,
  },
  {
    title: "Smart AgTech Solutions",
    description:
      "Modern farm management powered by data-driven irrigation, soil health monitoring, and eco-conscious growing practices.",
    href: "/services/ag-tech-solutions",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-tractor-icon lucide-tractor"><path d="m10 11 11 .9a1 1 0 0 1 .8 1.1l-.665 4.158a1 1 0 0 1-.988.842H20"/><path d="M16 18h-5"/><path d="M18 5a1 1 0 0 0-1 1v5.573"/><path d="M3 4h8.129a1 1 0 0 1 .99.863L13 11.246"/><path d="M4 11V4"/><path d="M7 15h.01"/><path d="M8 10.1V4"/><circle cx="18" cy="18" r="2"/><circle cx="7" cy="15" r="5"/></svg>`,
  },
  {
    title: "Eco-Friendly Pest Control",
    description:
      "Effective pest and mosquito treatments that protect your family and pollinators alike, without harsh chemicals.",
    href: "/services/plant-care",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-bug-icon lucide-bug"><path d="M12 20v-9"/><path d="M14 7a4 4 0 0 1 4 4v3a6 6 0 0 1-12 0v-3a4 4 0 0 1 4-4z"/><path d="M14.12 3.88 16 2"/><path d="M21 21a4 4 0 0 0-3.81-4"/><path d="M21 5a4 4 0 0 1-3.55 3.97"/><path d="M22 13h-4"/><path d="M3 21a4 4 0 0 1 3.81-4"/><path d="M3 5a4 4 0 0 0 3.55 3.97"/><path d="M6 13H2"/><path d="m8 2 1.88 1.88"/><path d="M9 7.13V6a3 3 0 1 1 6 0v1.13"/></svg>`,
  },
];
---

<header
  id="site-header"
  class="fixed top-4 sm:top-6 left-0 right-0 z-999 flex justify-center w-full px-4 sm:px-6"
>
  <div
    id="glass-nav"
    class="relative bg-cream/50 backdrop-blur-xl backdrop-saturate-150 border border-white/40 rounded-full w-full max-w-6xl flex items-center justify-between px-3 py-2.5 sm:px-4 sm:py-4 shadow-[0_8px_32px_rgba(0,0,0,0.08),inset_0_1px_1px_rgba(255,255,255,0.6)] overflow-visible transition-all duration-300"
  >
    <!-- Shine layer that follows cursor -->
    <div
      id="glass-shine"
      class="pointer-events-none absolute inset-0 opacity-0 transition-opacity duration-300 rounded-full"
      style="background: radial-gradient(180px circle at var(--x, 50%) var(--y, 50%), rgba(255,255,255,0.5), transparent 70%);"
    >
    </div>

    <!-- Logo -->
    <a href="/" class="relative flex items-center gap-2 sm:gap-3 shrink-0">
      <img
        class="w-9 h-9 sm:w-14 sm:h-14"
        fetchpriority="high"
        src="/logo.png"
        alt=""
        aria-hidden="true"
      />
      <span
        class="font-sora font-bold text-forest text-[0.85rem] sm:text-[1.1rem] leading-[1.9]"
      >
        <p class="font-extrabold text-2xl">Zahra</p>
        <p class="text-sm">Al Warsan</p>
      </span>
    </a>

    <!-- Nav (desktop) -->
    <nav class="relative hidden lg:flex items-center gap-8">
      <!-- Services with dropdown -->
      <div class="relative" data-dropdown-group>
        <button
          type="button"
          class="text-[15px] text-forest font-sora font-medium flex items-center gap-1 hover:opacity-80 transition-opacity cursor-pointer"
          data-dropdown-trigger
          aria-expanded="false"
        >
          Services
          <svg
            class="w-4 h-4 transition-transform duration-300"
            data-dropdown-chevron
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M19 9l-7 7-7-7"></path></svg
          >
        </button>

        <div
          data-dropdown-panel
          class="absolute left-1/2 -translate-x-1/2 top-full mt-10 w-[1000px] max-w-[92vw] bg-cream/95 backdrop-blur-xl backdrop-saturate-150 border border-white/40 rounded-4xl shadow-[0_24px_48px_rgba(0,0,0,0.1)] overflow-hidden z-50"
        >
          <div class="grid grid-cols-3 gap-2 p-3">
            {
              serviceMenuItems.map((item) => (
                <a
                  href={item.href}
                  class="group flex flex-col items-start gap-4 rounded-3xl p-6 hover:bg-teal transition-all duration-300 hover:shadow-[0_8px_30px_rgba(0,0,0,0.04)]"
                >
                  <div
                    class="w-12 h-12 rounded-2xl bg-forest/5 flex items-center justify-center text-forest group-hover:bg-white/10 group-hover:text-white transition-colors duration-300 shrink-0 shadow-sm"
                    set:html={item.icon}
                  />
                  <div class="flex flex-col gap-2 mt-1">
                    <span class="font-sora font-semibold text-base text-forest group-hover:text-white/60 transition-colors duration-300">
                      {item.title}
                    </span>
                    <span class="font-sora text-[13px] leading-relaxed text-forest/60 group-hover:text-white/60 transition-colors duration-300">
                      {item.description}
                    </span>
                  </div>
                </a>
              ))
            }
          </div>
        </div>
      </div>
      <a
        href="/portfolio"
        class="text-[15px] text-forest font-sora font-medium flex items-center gap-1 hover:opacity-80 transition-opacity"
      >
        Portfolio
      </a>
      <a
        href="/contact"
        class="text-[15px] text-forest font-sora font-medium flex items-center gap-1 hover:opacity-80 transition-opacity"
      >
        Contact
      </a>
    </nav>

    <!-- Right side: CTA + hamburger -->
    <div class="relative flex items-center gap-2 sm:gap-3">
      <!-- CTA -->

      <a
        href="/contact"
        class="bg-forest text-cream font-sora px-4 py-2 sm:px-6 sm:py-2.5
      rounded-full text-xs sm:text-[15px] font-medium hover:bg-forest/90
      transition-colors"
      >
        Get a Quote
      </a>

      <!-- Hamburger (mobile/tablet) -->
      <button
        id="mobile-menu-toggle"
        type="button"
        class="lg:hidden flex items-center justify-center w-9 h-9 sm:w-10 sm:h-10 rounded-full hover:bg-forest/10 transition-colors cursor-pointer"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <svg
          id="hamburger-icon"
          class="w-5 h-5 sm:w-6 sm:h-6 text-forest transition-opacity"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
        <svg
          id="close-icon"
          class="w-5 h-5 sm:w-6 sm:h-6 text-forest hidden transition-opacity"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu panel -->
  <div
    id="mobile-menu"
    class="lg:hidden absolute top-full left-4 right-4 sm:left-6 sm:right-6 mt-3 bg-cream/70 backdrop-blur-xl backdrop-saturate-150 border border-white/40 rounded-2xl shadow-[0_8px_32px_rgba(0,0,0,0.1)] overflow-hidden transition-all duration-500 ease-[cubic-bezier(0.16,1,0.3,1)] grid opacity-0 pointer-events-none"
    style="grid-template-rows: 0fr;"
  >
    <div class="min-h-0">
      <nav class="flex flex-col p-6 gap-2">
        <!-- Services Accordion -->
        <div class="flex flex-col" id="mobile-services-group">
          <button
            type="button"
            class="flex items-center justify-between text-base text-forest font-sora font-medium py-3 hover:text-teal transition-colors text-left w-full"
            id="mobile-services-toggle"
            aria-expanded="false"
          >
            <span>Services</span>
            <svg
              class="w-4 h-4 transition-transform duration-300"
              id="mobile-services-chevron"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M19 9l-7 7-7-7"></path>
            </svg>
          </button>

          <div
            id="mobile-services-panel"
            class="grid transition-all duration-300 ease-in-out"
            style="grid-template-rows: 0fr;"
          >
            <div class="overflow-hidden min-h-0 flex flex-col gap-2">
              {
                serviceMenuItems.map((item) => (
                  <a
                    href={item.href}
                    class="group flex items-center gap-4 py-3 rounded-2xl hover:bg-white/50 transition-colors"
                  >
                    <div
                      class="w-10 h-10 rounded-xl bg-forest/5 flex items-center justify-center text-forest group-hover:bg-teal group-hover:text-white transition-colors shrink-0 shadow-sm"
                      set:html={item.icon}
                    />
                    <span class="text-[14px] text-forest/90 font-sora font-medium group-hover:text-teal transition-colors">
                      {item.title}
                    </span>
                  </a>
                ))
              }
            </div>
          </div>
        </div>

        <a
          href="/portfolio"
          class="text-base text-forest font-sora font-medium py-3 hover:text-teal transition-colors block"
        >
          Portfolio
        </a>

        <a
          href="/contact"
          class="text-base text-forest font-sora font-medium py-3 hover:text-teal transition-colors block"
        >
          Contact
        </a>
      </nav>
    </div>
  </div>

  <script>
    function initMobileMenu() {
      const toggle = document.getElementById("mobile-menu-toggle");
      const menu = document.getElementById("mobile-menu");
      const hamburgerIcon = document.getElementById("hamburger-icon");
      const closeIcon = document.getElementById("close-icon");

      const servicesToggle = document.getElementById("mobile-services-toggle");
      const servicesPanel = document.getElementById("mobile-services-panel");
      const servicesChevron = document.getElementById(
        "mobile-services-chevron",
      );

      if (!toggle || !menu || !hamburgerIcon || !closeIcon) return;
      if (toggle.dataset.initialized === "true") return;
      toggle.dataset.initialized = "true";

      // Main mobile menu toggle
      toggle.addEventListener("click", () => {
        const isOpen = toggle.getAttribute("aria-expanded") === "true";
        toggle.setAttribute("aria-expanded", String(!isOpen));

        if (isOpen) {
          menu.style.gridTemplateRows = "0fr";
          menu.style.opacity = "0";
          menu.classList.add("pointer-events-none");
          hamburgerIcon.classList.remove("hidden");
          closeIcon.classList.add("hidden");

          // Optionally close services sub-menu when main menu closes
          if (servicesToggle?.getAttribute("aria-expanded") === "true") {
            servicesToggle.setAttribute("aria-expanded", "false");
            if (servicesPanel) servicesPanel.style.gridTemplateRows = "0fr";
            if (servicesChevron) servicesChevron.classList.remove("rotate-180");
          }
        } else {
          menu.style.gridTemplateRows = "1fr";
          menu.style.opacity = "1";
          menu.classList.remove("pointer-events-none");
          hamburgerIcon.classList.add("hidden");
          closeIcon.classList.remove("hidden");
        }
      });

      // Mobile services sub-menu toggle
      if (servicesToggle && servicesPanel && servicesChevron) {
        servicesToggle.addEventListener("click", () => {
          const isOpen =
            servicesToggle.getAttribute("aria-expanded") === "true";
          servicesToggle.setAttribute("aria-expanded", String(!isOpen));

          if (isOpen) {
            servicesPanel.style.gridTemplateRows = "0fr";
            servicesChevron.classList.remove("rotate-180");
          } else {
            servicesPanel.style.gridTemplateRows = "1fr";
            servicesChevron.classList.add("rotate-180");
          }
        });
      }
    }

    // function initGlassEffects() {
    //   const nav = document.getElementById("glass-nav");
    //   const shine = document.getElementById("glass-shine");
    //   if (!nav || !shine) return;
    //   if (nav.dataset.initialized === "true") return;
    //   nav.dataset.initialized = "true";

    //   nav.addEventListener("mousemove", (e) => {
    //     const rect = nav.getBoundingClientRect();
    //     const x = ((e.clientX - rect.left) / rect.width) * 100;
    //     const y = ((e.clientY - rect.top) / rect.height) * 100;
    //     nav.style.setProperty("--x", `${x}%`);
    //     nav.style.setProperty("--y", `${y}%`);
    //   });

    //   nav.addEventListener("mouseenter", () => {
    //     shine.style.opacity = "1";
    //   });

    //   nav.addEventListener("mouseleave", () => {
    //     shine.style.opacity = "0";
    //   });

    //   let ticking = false;
    //   function updateOnScroll() {
    //     const scrollY = window.scrollY;
    //     const progress = Math.min(scrollY / 120, 1);
    //     const blur = 12 + progress * 12;
    //     const bgOpacity = 0.5 + progress * 0.25;

    //     nav.style.backdropFilter = `blur(${blur}px) saturate(150%)`;
    //     (nav.style as any).webkitBackdropFilter =
    //       `blur(${blur}px) saturate(150%)`;
    //     nav.style.backgroundColor = `rgba(245, 231, 207, ${bgOpacity})`;

    //     ticking = false;
    //   }

    //   window.addEventListener("scroll", () => {
    //     if (!ticking) {
    //       requestAnimationFrame(updateOnScroll);
    //       ticking = true;
    //     }
    //   });

    //   updateOnScroll();
    // }

    function initDropdown() {
      const groups = document.querySelectorAll<HTMLElement>(
        "[data-dropdown-group]",
      );

      groups.forEach((group) => {
        if (group.dataset.initialized === "true") return;
        group.dataset.initialized = "true";

        const trigger = group.querySelector<HTMLButtonElement>(
          "[data-dropdown-trigger]",
        );
        const panel = group.querySelector<HTMLElement>("[data-dropdown-panel]");
        const chevron = group.querySelector<SVGElement>(
          "[data-dropdown-chevron]",
        );

        if (!trigger || !panel) return;

        let closeTimeout: ReturnType<typeof setTimeout>;

        function open() {
          clearTimeout(closeTimeout);
          panel!.classList.add("is-open");
          trigger!.setAttribute("aria-expanded", "true");
          chevron?.classList.add("rotate-180");
        }

        function close() {
          closeTimeout = setTimeout(() => {
            panel!.classList.remove("is-open");
            trigger!.setAttribute("aria-expanded", "false");
            chevron?.classList.remove("rotate-180");
          }, 120);
        }

        group.addEventListener("mouseenter", open);
        group.addEventListener("mouseleave", close);

        trigger.addEventListener("click", () => {
          const isOpen = trigger.getAttribute("aria-expanded") === "true";
          isOpen ? close() : open();
        });

        document.addEventListener("click", (e) => {
          if (!group.contains(e.target as Node)) close();
        });
      });
    }

    function initAll() {
      initMobileMenu();
      // initGlassEffects();
      initDropdown();
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", initAll);
    } else {
      initAll();
    }

    document.addEventListener("astro:page-load", initAll);
  </script>
</header>

<style>
  /* 3D Flag Unfold Animation for Desktop Dropdown */
  [data-dropdown-panel] {
    opacity: 0;
    transform-origin: top center;
    transform: perspective(1200px) rotateX(-60deg) translateY(-20px);
    pointer-events: none;
    transition:
      transform 0.5s cubic-bezier(0.16, 1, 0.3, 1),
      opacity 0.3s ease-out;
  }

  [data-dropdown-panel].is-open {
    opacity: 1;
    pointer-events: auto;
    transform: perspective(1200px) rotateX(0deg) translateY(0);
    /* Add a slight bounce on the unfold */
    transition:
      transform 0.6s cubic-bezier(0.34, 1.56, 0.64, 1),
      opacity 0.4s ease-out;
  }
</style>
