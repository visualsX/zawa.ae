        <!-- Duplicate for seamless loop -->
        <span class="marquee-item">Lawn & Garden Fertilization</span>
        <span class="marquee-separator">&bull;</span>
        <span class="marquee-item">Landscape Design & Execution</span>
        <span class="marquee-separator">&bull;</span>
        <span class="marquee-item">Softscape & Hardscape</span>
        <span class="marquee-separator">&bull;</span>
        <span class="marquee-item">Household Pest Control</span>
        <span class="marquee-separator">&bull;</span>
        <span class="marquee-item">Irrigation Systems</span>
        <span class="marquee-separator">&bull;</span>
        <span class="marquee-item">Commercial & Educational Services</span>
        <span class="marquee-separator">&bull;</span>
        <span class="marquee-item">Flea & Tick Control</span>
        <span class="marquee-separator">&bull;</span>
        <span class="marquee-item">Annual Maintenance Contracts (AMC)</span>
        <span class="marquee-separator">&bull;</span>
        <span class="marquee-item">Greenhouse & Net House Construction</span>
