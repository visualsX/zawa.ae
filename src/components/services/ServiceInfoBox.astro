---
export interface Props {
  question: string;
  subtext: string;
}

const { question, subtext } = Astro.props;
---

<section class="relative z-20 bg-cream pt-12 pb-16 md:px-6">
  <div class="container-custom max-w-fit">
    <div
      class="relative bg-black/10 rounded-xl px-4 pb-4 pt-8 md:p-4 flex flex-row items-center gap-6 shadow-sm"
    >
      <img
        class="w-12 h-12 md:w-8 md:h-8 absolute top-0 bg-cream md:bg-transparent p-2 md:p-0 rounded-md left-1/2 -translate-x-1/2 -translate-y-1/2 md:translate-x-0 md:translate-y-0 md:top-0 md:left-0 md:relative"
        src="/icons/business.svg"
        alt=""
      />
      <div class="rounded-lg text-center md:text-left">
        <h1 class="font-sora text-forest font-bold">
          {question}
        </h1>
        <p class="font-normal text-forest/80">{subtext}</p>
      </div>
    </div>
  </div>
</section>
