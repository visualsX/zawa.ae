---
interface ServiceCard {
  title: string;
  image: string;
  alt: string;
  href?: string;
}

const cards: ServiceCard[] = [
  {
    title: "Complete plant care &<br />landscape design",
    image:
      "https://images.unsplash.com/photo-1584622650111-993a426fbf0a?q=80&w=800&auto=format&fit=crop",
    alt: "andscape design",
    href: "#",
  },
  {
    title: "Sustainable farms &<br />smart AgTech solutions",
    image:
      "https://images.unsplash.com/photo-1584622650111-993a426fbf0a?q=80&w=800&auto=format&fit=crop",
    alt: "AgTech solutions",
    href: "#",
  },
  {
    title: "Kid, pet & bee friendly<br />pest & mosquito control",
    image:
      "https://images.unsplash.com/photo-1584622650111-993a426fbf0a?q=80&w=800&auto=format&fit=crop",
    alt: "Pest control",
    href: "#",
  },
];
---

<section class="w-full bg-forest py-24 md:py-32 relative z-20">
  <div class="container-custom">
    <!-- Header -->
    <div class="mb-16">
      <h2
        class="font-awesome text-6xl md:text-7xl text-cream m-0 text-center font-normal leading-[1.15]"
      >
        <span class="block">For work or home, we make your</span>
        <span class="block">landscape the best you've known</span>
      </h2>
    </div>

    <!-- Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 lg:gap-5">
      {
        cards.map((card) => (
          <a
            href={card.href ?? "#"}
            class="group flex flex-col rounded-md overflow-hidden bg-white/5 hover:bg-rust transition-colors duration-300"
          >
            <div class="h-64 sm:h-72 w-full overflow-hidden">
              <img
                src={card.image}
                alt={card.alt}
                class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-110"
              />
            </div>
            <div class="p-8 flex justify-between items-end gap-6 grow">
              <h3
                class="font-beautify text-2xl font-normal leading-tight text-cream m-0"
                set:html={card.title}
              />
              <svg
                class="w-6 h-6 shrink-0 text-cream/70 group-hover:text-cream transition-colors mb-1"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="1.5"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M9 5l7 7-7 7"
                />
              </svg>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</section>
