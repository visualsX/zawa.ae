---
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <!-- Hero Section -->
  <section
    class="relative z-20 w-full bg-forest pt-40 pb-24 px-4 sm:px-6 overflow-hidden"
  >
    <div
      class="container-custom relative z-10 flex flex-col md:flex-row items-center justify-between gap-12"
    >
      <div class="max-w-2xl">
        <h1
          class="font-awesome text-4xl sm:text-5xl md:text-6xl text-cream font-bold mb-6 leading-tight"
        >
          Get In Touch
        </h1>
        <p class="text-cream/90 text-lg sm:text-xl mb-8 max-w-xl font-sora">
          Whether you have a question about our services, need a consultation,
          or want to start a project, we'd love to hear from you.
        </p>
        <img
          fetchpriority="high"
          src="/icons/contact.svg"
          alt=""
          class="absolute z-1 pointer-events-none right-0 top-0 w-96 sm:w-60 md:w-70 hidden md:block opacity-20"
          aria-hidden="true"
        />
      </div>
    </div>
  </section>

  <!-- Contact Form + Info Section -->
  <section class="relative z-20 bg-cream py-16 sm:py-24 md:py-32 md:px-6">
    <div
      class="container-custom grid grid-cols-1 lg:grid-cols-5 gap-12 lg:gap-16"
    >
      <!-- Left: Contact Info -->
      <div class="lg:col-span-2 flex flex-col gap-10">
        <div>
          <h2
            class="font-awesome text-3xl sm:text-4xl text-forest font-bold mb-4 leading-tight"
          >
            Let's start something great together
          </h2>
          <p class="font-sora text-forest/70 text-base leading-relaxed">
            Fill out the form and our team will get back to you within 24 hours.
            You can also reach us directly through the details below.
          </p>
        </div>

        <div class="flex flex-col gap-6">
          <!-- Email -->
          <div class="flex items-start gap-4">
            <div
              class="w-12 h-12 rounded-xl bg-teal/10 flex items-center justify-center shrink-0"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="22"
                height="22"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="text-teal"
              >
                <rect width="20" height="16" x="2" y="4" rx="2"></rect>
                <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
              </svg>
            </div>
            <div>
              <span
                class="block font-sora text-xs text-forest/50 font-medium tracking-wider uppercase mb-1"
                >Email</span
              >
              <a
                href="mailto:zahraalwarsan@gmail.com"
                class="font-sora text-sm text-forest hover:text-teal transition-colors"
                >zahraalwarsan@gmail.com</a
              >
            </div>
          </div>

          <!-- Phone -->
          <div class="flex items-start gap-4">
            <div
              class="w-12 h-12 rounded-xl bg-teal/10 flex items-center justify-center shrink-0"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="22"
                height="22"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="text-teal"
              >
                <path
                  d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"
                ></path>
              </svg>
            </div>
            <div>
              <span
                class="block font-sora text-xs text-forest/50 font-medium tracking-wider uppercase mb-1"
                >Phone</span
              >
              <a
                href="tel:+971567788559"
                class="font-sora text-sm text-forest hover:text-teal transition-colors"
                >+971 56 778 8559</a
              >
            </div>
          </div>

          <!-- Location -->
          <div class="flex items-start gap-4">
            <div
              class="w-12 h-12 rounded-xl bg-teal/10 flex items-center justify-center shrink-0"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="22"
                height="22"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="text-teal"
              >
                <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"></path>
                <circle cx="12" cy="10" r="3"></circle>
              </svg>
            </div>
            <div>
              <span
                class="block font-sora text-xs text-forest/50 font-medium tracking-wider uppercase mb-1"
                >Location</span
              >
              <p class="font-sora text-sm text-forest">
                Dubai, United Arab Emirates
              </p>
            </div>
          </div>
        </div>
      </div>

      <!-- Right: Contact Form -->
      <div class="lg:col-span-3">
        <form
          id="contact-form"
          class="bg-olive rounded-2xl p-6 sm:p-8 md:p-10 shadow-elevated"
        >
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 mb-5">
            <!-- Name -->
            <div class="flex flex-col gap-2">
              <label
                for="contact-name"
                class="font-sora text-sm font-medium text-cream"
                >Full Name</label
              >
              <input
                type="text"
                id="contact-name"
                name="name"
                required
                placeholder="Your name"
                class="w-full px-4 py-3 rounded-xl border border-forest/15 bg-cream/30 font-sora text-sm text-cream placeholder:text-cream/30 outline-none focus:border-teal focus:ring-2 focus:ring-teal/20 transition-all"
              />
            </div>

            <!-- Email -->
            <div class="flex flex-col gap-2">
              <label
                for="contact-email"
                class="font-sora text-sm font-medium text-cream"
                >Email Address</label
              >
              <input
                type="email"
                id="contact-email"
                name="email"
                required
                placeholder="you@example.com"
                class="w-full px-4 py-3 rounded-xl border border-forest/15 bg-cream/30 font-sora text-sm text-cream placeholder:text-cream/30 outline-none focus:border-teal focus:ring-2 focus:ring-teal/20 transition-all"
              />
            </div>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 mb-5">
            <!-- Phone -->
            <div class="flex flex-col gap-2">
              <label
                for="contact-phone"
                class="font-sora text-sm font-medium text-cream"
                >Phone Number</label
              >
              <input
                type="tel"
                id="contact-phone"
                name="phone"
                placeholder="+971 XX XXX XXXX"
                class="w-full px-4 py-3 rounded-xl border border-forest/15 bg-cream/30 font-sora text-sm text-cream placeholder:text-cream/30 outline-none focus:border-teal focus:ring-2 focus:ring-teal/20 transition-all"
              />
            </div>

            <!-- Subject -->
            <div class="flex flex-col gap-2">
              <label
                for="contact-subject"
                class="font-sora text-sm font-medium text-cream">Subject</label
              >
              <input
                type="text"
                id="contact-subject"
                name="subject"
                required
                placeholder="How can we help?"
                class="w-full px-4 py-3 rounded-xl border border-forest/15 bg-cream/30 font-sora text-sm text-cream placeholder:text-cream/30 outline-none focus:border-teal focus:ring-2 focus:ring-teal/20 transition-all"
              />
            </div>
          </div>

          <!-- Message -->
          <div class="flex flex-col gap-2 mb-6">
            <label
              for="contact-message"
              class="font-sora text-sm font-medium text-cream">Message</label
            >
            <textarea
              id="contact-message"
              name="message"
              required
              rows="5"
              placeholder="Tell us about your project or question..."
              class="w-full px-4 py-3 rounded-xl border border-forest/15 bg-cream/30 font-sora text-sm text-cream placeholder:text-cream/30 outline-none focus:border-teal focus:ring-2 focus:ring-teal/20 transition-all resize-none"
            ></textarea>
          </div>

          <!-- Submit Button -->
          <button
            type="submit"
            class="w-full sm:w-auto inline-flex items-center justify-center gap-2 bg-black/70 text-white font-sora font-semibold px-10 py-3.5 rounded-full hover:bg-opacity-90 transition-all duration-300 transform hover:-translate-y-0.5 shadow-lg cursor-pointer"
          >
            Send Message
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="m22 2-7 20-4-9-9-4Z"></path>
              <path d="M22 2 11 13"></path>
            </svg>
          </button>
        </form>
      </div>
    </div>
  </section>

  <!-- Modal -->
  <div
    id="status-modal"
    class="fixed inset-0 z-50 hidden items-center justify-center bg-black/60 backdrop-blur-sm p-4"
  >
    <div
      class="bg-cream rounded-2xl p-8 max-w-sm w-full shadow-2xl transform transition-all scale-95 opacity-0 text-center"
      id="modal-content"
    >
      <div
        id="modal-icon"
        class="w-16 h-16 rounded-full mx-auto mb-4 flex items-center justify-center"
      >
        <!-- Icon injected via JS -->
      </div>
      <h3
        id="modal-title"
        class="font-awesome text-2xl text-forest font-bold mb-2"
      >
        Status
      </h3>
      <p id="modal-message" class="font-sora text-forest/80 mb-6">
        Message goes here
      </p>
      <button
        id="close-modal"
        class="bg-forest text-cream font-sora font-semibold px-8 py-3 rounded-full hover:bg-forest/90 transition-colors w-full cursor-pointer"
      >
        Close
      </button>
    </div>
  </div>

  <script>
    document.addEventListener("DOMContentLoaded", () => {
      const form = document.getElementById(
        "contact-form",
      ) as HTMLFormElement | null;
      const submitBtn = form?.querySelector(
        'button[type="submit"]',
      ) as HTMLButtonElement | null;
      const originalBtnText = submitBtn?.innerHTML || "";

      const modal = document.getElementById("status-modal");
      const modalContent = document.getElementById("modal-content");
      const modalIcon = document.getElementById("modal-icon");
      const modalTitle = document.getElementById("modal-title");
      const modalMessage = document.getElementById("modal-message");
      const closeModalBtn = document.getElementById("close-modal");

      const showModal = (type: "success" | "error", message: string) => {
        if (
          !modal ||
          !modalContent ||
          !modalIcon ||
          !modalTitle ||
          !modalMessage
        )
          return;

        modal.classList.remove("hidden");
        modal.classList.add("flex");

        // Trigger reflow
        void modal.offsetWidth;

        modalContent.classList.remove("scale-95", "opacity-0");
        modalContent.classList.add("scale-100", "opacity-100");

        if (type === "success") {
          modalIcon.className =
            "w-16 h-16 rounded-full mx-auto mb-4 flex items-center justify-center bg-white/20 text-olive";
          modalIcon.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><path d="m9 11 3 3L22 4"></path></svg>`;
          modalTitle.textContent = "Success!";
        } else {
          modalIcon.className =
            "w-16 h-16 rounded-full mx-auto mb-4 flex items-center justify-center bg-white/20 text-olive";
          modalIcon.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="15" y1="9" x2="9" y2="15"></line><line x1="9" y1="9" x2="15" y2="15"></line></svg>`;
          modalTitle.textContent = "Oops!";
        }

        modalMessage.textContent = message;
      };

      const hideModal = () => {
        if (!modal || !modalContent) return;

        modalContent.classList.remove("scale-100", "opacity-100");
        modalContent.classList.add("scale-95", "opacity-0");

        setTimeout(() => {
          modal.classList.remove("flex");
          modal.classList.add("hidden");
        }, 300);
      };

      closeModalBtn?.addEventListener("click", hideModal);

      // Close modal on outside click
      modal?.addEventListener("click", (e) => {
        if (e.target === modal) {
          hideModal();
        }
      });

      form?.addEventListener("submit", async (e) => {
        e.preventDefault();

        if (!submitBtn) return;

        // Disable button and show loading state
        submitBtn.disabled = true;
        submitBtn.innerHTML = `
          Sending...
          <svg class="animate-spin ml-2 h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
        `;

        const formData = new FormData(form);
        const apiData = new FormData();

        apiData.append("Name", formData.get("name") as string);
        apiData.append("Email", formData.get("email") as string);

        const phone = formData.get("phone") as string;
        if (phone) {
          apiData.append("PhoneNumber", phone);
        }

        apiData.append("Subject", formData.get("subject") as string);
        apiData.append("Message", formData.get("message") as string);

        try {
          const response = await fetch("https://api.gardenhub.ae/api/Contact", {
            method: "POST",
            body: apiData,
          });

          if (response.ok) {
            form.reset();
            showModal(
              "success",
              "Your message has been sent successfully. We will get back to you soon!",
            );
          } else {
            showModal(
              "error",
              "Failed to send message. Please try again later.",
            );
          }
        } catch (error) {
          console.error("Submission error:", error);
          showModal(
            "error",
            "An error occurred while sending your message. Please check your connection and try again.",
          );
        } finally {
          submitBtn.disabled = false;
          submitBtn.innerHTML = originalBtnText;
        }
      });
    });
  </script>
</Layout>
