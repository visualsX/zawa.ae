---
import Marquee from "../../Marquee.astro";
---

<section
  class="w-full bg-cream py-16 sm:py-20 md:py-24 relative z-20 flex flex-col items-center overflow-hidden"
>
  <!-- Marquee Heading -->
  <div class="w-full mb-12 sm:mb-20 md:mb-28">
    <Marquee
      items={[
        "The new standard of indoor & outdoor living",
        "The new standard of indoor & outdoor living",
        "The new standard of indoor & outdoor living",
        "The new standard of indoor & outdoor living",
        "The new standard of indoor & outdoor living",
        "The new standard of indoor & outdoor living",
      ]}
      speed={120}
      gap="1rem"
      textClass="font-awesome font-medium text-[2.5rem] sm:text-[3.5rem] md:text-[4.5rem] lg:text-[6.5rem] leading-[1.1] text-teal tracking-tight"
      dotClass="font-awesome font-medium text-teal text-[2.5rem] sm:text-[3.5rem] md:text-[4.5rem] lg:text-[6.5rem] leading-[1.1] px-2"
    />
  </div>

  <!-- Icon Cards -->
  <div
    class="grid grid-cols-2 sm:grid-cols-4 gap-4 sm:gap-6 md:gap-8 lg:gap-12 container-custom"
  >
    <!-- Card 1 -->
    <div
      class="bg-white/30 rounded-[100vw] shadow-[0_8px_30px_rgb(0,0,0,0.04)] aspect-3/4.5 flex flex-col items-center justify-center p-4 sm:p-6 md:p-8 gap-4 sm:gap-6 md:gap-8 hover:-translate-y-2 transition-transform duration-300"
    >
      <div
        class="w-16 h-16 sm:w-20 sm:h-20 md:w-24 md:h-24 lg:w-28 lg:h-28 flex items-center justify-center fill-forest"
      >
        <img
          src="/icons/buzz.svg"
          alt="Ready when you are"
          class="w-full h-full object-contain"
        />
      </div>
      <p
        class="font-almendra font-normal text-forest text-xs sm:text-sm md:text-lg lg:text-xl text-center leading-tight"
      >
        Ready when<br /> you are
      </p>
    </div>

    <!-- Card 2 -->
    <div
      class="bg-white/30 rounded-[100vw] shadow-[0_8px_30px_rgb(0,0,0,0.04)] aspect-3/4.5 flex flex-col items-center justify-center p-4 sm:p-6 md:p-8 gap-4 sm:gap-6 md:gap-8 hover:-translate-y-2 transition-transform duration-300"
    >
      <div
        class="w-16 h-16 sm:w-20 sm:h-20 md:w-24 md:h-24 lg:w-28 lg:h-28 flex items-center justify-center text-forest"
      >
        <img
          src="/icons/24by7.svg"
          alt="Seamless services"
          class="w-full h-full object-contain"
        />
      </div>
      <p
        class="font-almendra font-normal text-forest text-xs sm:text-sm md:text-lg lg:text-xl text-center leading-tight"
      >
        Seamless<br />services
      </p>
    </div>

    <!-- Card 3 -->
    <div
      class="bg-white/30 rounded-[100vw] shadow-[0_8px_30px_rgb(0,0,0,0.04)] aspect-3/4.5 flex flex-col items-center justify-center p-4 sm:p-6 md:p-8 gap-4 sm:gap-6 md:gap-8 hover:-translate-y-2 transition-transform duration-300"
    >
      <div
        class="w-16 h-16 sm:w-20 sm:h-20 md:w-24 md:h-24 lg:w-28 lg:h-28 flex items-center justify-center text-forest"
      >
        <img
          src="/icons/ecofriendly.svg"
          alt="Eco-friendly practices"
          class="w-full h-full object-contain"
        />
      </div>
      <p
        class="font-almendra font-normal text-forest text-xs sm:text-sm md:text-lg lg:text-xl text-center leading-tight"
      >
        Eco-friendly<br />practices
      </p>
    </div>

    <!-- Card 4 -->
    <div
      class="bg-white/30 rounded-[100vw] shadow-[0_8px_30px_rgb(0,0,0,0.04)] aspect-3/4.5 flex flex-col items-center justify-center p-4 sm:p-6 md:p-8 gap-4 sm:gap-6 md:gap-8 hover:-translate-y-2 transition-transform duration-300"
    >
      <div
        class="w-16 h-16 sm:w-20 sm:h-20 md:w-24 md:h-24 lg:w-28 lg:h-28 flex items-center justify-center text-forest"
      >
        <img
          src="/icons/backup.svg"
          alt="Backup equipment"
          class="w-full h-full object-contain"
        />
      </div>
      <p
        class="font-almendra font-normal text-forest text-xs sm:text-sm md:text-lg lg:text-xl text-center leading-tight"
      >
        Backup<br />equipment
      </p>
    </div>
  </div>
</section>
